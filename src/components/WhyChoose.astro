---
import { benefits, metrics, brand, whatsappLink } from "@data/content";
---

<section class="section section-navy" aria-labelledby="why-title">
  <div class="content-shell split-layout">
    <div class="section-heading section-heading-invert">
      <p class="eyebrow">Por qué elegirnos</p>
      <h2 id="why-title">Operación cercana, rápida y pensada para negocios que necesitan cumplir.</h2>
    </div>

    <div class="benefit-panel" aria-label="Beneficios principales">
      <div class="metric-grid">
        {metrics.map((metric) => (
          <div class="metric-item">
            <strong>{metric.value}</strong>
            <span>{metric.label}</span>
          </div>
        ))}
      </div>
      <ul class="benefit-list">
        {benefits.map((benefit) => <li>{benefit}</li>)}
      </ul>
      <p class="contact-note">WhatsApp: {brand.phones.quote} / {brand.phones.attention}</p>
    </div>
  </div>
</section>

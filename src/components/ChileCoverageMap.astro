---

<div class="chile-map" aria-label="Mapa de cobertura regional de Entregas Chapu">



  <div class="chile-map__inner" aria-hidden="false">
    <svg
      class="chile-map__svg"
      viewBox="508 112 104 130"
      width="104"
      height="130"
      preserveAspectRatio="xMidYMid meet"
      role="img"
      aria-labelledby="coverage-map-title coverage-map-description"
      xmlns="http://www.w3.org/2000/svg"
    >
      <title id="coverage-map-title">Cobertura regional Atacama y Coquimbo</title>
      <desc id="coverage-map-description">
        Mapa reducido a las regiones de Atacama y Coquimbo con paradas referenciales en El Salvador, Diego de Almagro, Chañaral, Caldera, Copiapó, Vallenar, La Serena y Coquimbo.
      </desc>

      <defs>
        <linearGradient id="coverage-region-gradient" x1="540" y1="112" x2="590" y2="242" gradientUnits="userSpaceOnUse">



        <stop offset="0%" stop-color="#efd9b2" />
        <stop offset="42%" stop-color="#d2a66d" />
        <stop offset="100%" stop-color="#b87a42" />




        </linearGradient>
      </defs>

      <g class="chile-map__regions">
        <path
          id="CL-AT"
          class="chile-map__region chile-map__region--atacama"
          data-region="Atacama"
          d={atacamaPath}
        />

        <path
          id="CL-CO"
          class="chile-map__region chile-map__region--coquimbo"
          data-region="Coquimbo"
          d={coquimboPath}
        />
      </g>

      <g class="chile-map__route" aria-hidden="true">
        <path class="chile-map__route-halo" d={routePath} />
        <path class="chile-map__route-line" d={routePath} />
      </g>



      <g class="chile-map__stops">
        {routeStops.map((stop) => (
          <g class="chile-map__stop">
            <title>{stop.name}</title>
            <line
              class="chile-map__leader"
              x1={stop.leaderStartX}
              y1={stop.labelY - 1.4}
              x2={stop.leaderEndX}
              y2={stop.y}
            />


            <circle class="chile-map__pin-ring" cx={stop.x} cy={stop.y} r="2.35" />
            <circle class="chile-map__pin-core" cx={stop.x} cy={stop.y} r="1.05" />




            <text
              class="chile-map__label"
              x={stop.labelX}
              y={stop.labelY}
              text-anchor={stop.anchor}
            >
              {stop.name}
            </text>
          </g>
        ))}
      </g>




      
    </svg>
  </div>

</div>

<style>
  .chile-map {
    width: min(430px, 100%);
    margin: 0;
    line-height: 0;
  }

  .chile-map__inner {
    display: flex;
    justify-content: center;
  }

    .chile-map__svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
    filter:
        drop-shadow(0 -10px 16px rgba(255, 255, 255, 0.85))
        drop-shadow(0 16px 24px rgba(6, 27, 58, 0.1));
    }

    .chile-map__region {
    fill: url(#coverage-region-gradient);
    stroke: rgba(255, 255, 255, 0.86);
    stroke-width: 0.55;
    vector-effect: non-scaling-stroke;
    }

  .chile-map__region--atacama {
    opacity: 1;
  }

  .chile-map__region--coquimbo {
    opacity: 0.96;
  }

  .chile-map__route-halo,
  .chile-map__route-line {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }

    .chile-map__route-halo {
    stroke: rgba(255, 255, 255, 0.62);
    stroke-width: 1.8;
    }

    .chile-map__route-line {
    stroke: rgba(201, 8, 19, 0.72);
    stroke-width: 0.75;
    stroke-dasharray: 0.8 2.8;
    }

  .chile-map__leader {
    stroke: rgba(6, 27, 58, 0.22);
    stroke-width: 0.42;
    vector-effect: non-scaling-stroke;
  }



    .chile-map__pin-ring {
    fill: rgba(255, 255, 255, 0.92);
    stroke: rgba(201, 8, 19, 0.72);
    stroke-width: 0.65;
    vector-effect: non-scaling-stroke;
    }

    .chile-map__pin-core {
    fill: rgba(6, 27, 58, 0.78);
    }





  .chile-map__label {
    fill: var(--navy, #061b3a);
    font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 3.75px;
    font-weight: 850;
    letter-spacing: 0;
    paint-order: stroke;
    stroke: rgba(255, 255, 255, 0.92);
    stroke-width: 1.55;
    stroke-linejoin: round;
  }

  @media (max-width: 520px) {
    .chile-map__label,
    .chile-map__leader {
      display: none;
    }
  }
</style>

---
import "../styles/global.css";
import "../styles/animations.css";
import "../styles/contact-polish.css";
import "../styles/footer-polish.css";

interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image = "/assets/entregas-chapu-van.jpeg" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#061b3a" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={image} />
    <title>{title}</title>


    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=AW-18270123444"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'AW-18270123444');
    </script>




  </head>
  <body>
    <slot />
  </body>
</html>
